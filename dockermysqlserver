CREATE IMAGE : docker run -d \                              
  --name mysql-server   -e MYSQL_ROOT_PASSWORD=myrootpassword   -e MYSQL_DATABASE=mydatabase   -e MYSQL_USER=myuser   -e MYSQL_PASSWORD=mypassword   -p 3306:3306   -v mysql_data:/var/lib/mysql   mysql:8.0

ACCESSING  IT FROM TERMINAL : docker exec -it mysql-server mysql -u root -p 
STARTING IMAGE : docker start imagename 
STOPPING  IMAGE : docker stop imagename 
